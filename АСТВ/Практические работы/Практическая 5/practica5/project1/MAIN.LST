0160 75A000           59            MOV     P2, #0
                      60            
                      61            ; Show pressed key
0163 F580             62            MOV     P0, A
0165 75A003           63            MOV     P2, #3
0168 75A002           64            MOV     P2, #2
                      65            
                      66            ; ===== WAIT FOR KEY TO BE RELEASED =====
016B                  67    WAIT_RELEASE:
016B 12018C           68            LCALL   GET_KEY
016E B4FFFA           69            CJNE    A, #0FFH, WAIT_RELEASE
                      70            
                      71            ; Delay after release (10ms)
0171 7D02             72            MOV     R5, #2           ; 2 x 5ms = 10ms
0173 120178           73            LCALL   DELAY_MS
                      74            
0176 80CC             75            SJMP    MAIN
                      76    
                      77    ;=============================================================================
                      78    ; TIMER DELAY FUNCTION (5ms base)
                      79    ; Input: R5 = number of 5ms intervals
                      80    ;=============================================================================
0178                  81    DELAY_MS:
0178                  82    DELAY_LOOP:
                      83            ; Load timer for 5ms (5000 ticks at 12MHz)
                      84            ; 65536 - 5000 = 60536 = 0xEC78
0178 758CEC           85            MOV     TH0, #0ECH       ; High byte: 0xEC
017B 758A78           86            MOV     TL0, #078H       ; Low byte: 0x78
017E C28D             87            CLR     TF0              ; Clear overflow flag
0180 D28C             88            SETB    TR0              ; Start timer
                      89            
0182                  90    WAIT_TICK:
0182 308DFD           91            JNB     TF0, WAIT_TICK   ; Wait for overflow (TF0 becomes 1)
0185 C28C             92            CLR     TR0              ; Stop timer
0187 C28D             93            CLR     TF0              ; Clear flag for next use
                      94            
0189 DDED             95            DJNZ    R5, DELAY_LOOP   ; Repeat R5 times
018B 22               96            RET
                      97    
                      98    ;=============================================================================
                      99    ; KEYPAD SCANNING
                     100    ;=============================================================================
018C                 101    GET_KEY:
                     102            ; Scan column 0 (P1.0 = 0)
018C 7590F0          103            MOV     P1, #0F0H
018F C290            104            CLR     P1.0
0191 D291            105            SETB    P1.1
0193 D292            106            SETB    P1.2
0195 D293            107            SETB    P1.3
0197 7D01            108            MOV     R5, #1           ; 5ms delay for signal stabilization
0199 120178          109            LCALL   DELAY_MS
019C E590            110            MOV     A, P1
019E 54F0            111            ANL     A, #0F0H
01A0 B4F048          112            CJNE    A, #0F0H, FOUND0
                     113            
                     114            ; Scan column 1 (P1.1 = 0)
01A3 7590F0          115            MOV     P1, #0F0H
01A6 D290            116            SETB    P1.0
